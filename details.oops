import java.util.ArrayList;  
  
class Course {  
    int id;  
    String name;  
  
    Course(int id, String name) {  
        this.id = id;  
        this.name = name;  
    }  
}  
  
class Student {  
    int id;  
    String name;  
    ArrayList<Course> courses = new ArrayList<>();  
  
    Student(int id, String name) {  
        this.id = id;  
        this.name = name;  
    }  
  
    void enroll(Course c) {  
        courses.add(c);  
    }  
  
    void display() {         for (Course c : 
courses) {             
System.out.println(c.name);  
        }  
    }  
}  
  
class EnrollmentSystem {  
    ArrayList<Student> students = new ArrayList<>();  
    ArrayList<Course> courses = new ArrayList<>();  
  
    void addStudent(Student s) {  
        students.add(s);  
    }  
  
    void addCourse(Course c) {  
        courses.add(c);  
    }  
  
    Student findStudent(int id) {         
for (Student s : students) {             
if (s.id == id)  
                return s;  
        }  
        return null;  
    }  
  
    Course findCourse(int id) {  
        for (Course c : courses) {             
if (c.id == id)  
                return c;  
        }  
        return null;  
    }  
  
    void enrollStudent(int sid, int cid) {         
Student s = findStudent(sid);         
Course c = findCourse(cid);         if (s != 
null && c != null) {             s.enroll(c);  
        }  
    }  
}  
  
public class Main {  
    public static void main(String[] args) {  
  
        EnrollmentSystem sys = new EnrollmentSystem();  
  
        Student s = new Student(1, "Aswini");  
        Course c = new Course(101, "Java");  
  
        sys.addStudent(s);  
sys.addCourse(c);  
sys.enrollStudent(1, 101);  
s.display();  
} 
}  
